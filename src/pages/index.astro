---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TechPill from "../components/TechPill.astro";

const skills = [
  "Backend .Net",
  "Full stack web development",
  "Mobile, Desktop, Hybrid",
  "Scrum / Agile",
  "Customer Service",
  "Incident Resolution",
  "Smart Games",
];

const technologies = [
  "Office 360",
  "CSS",
  "C#",
  "SQL",
  "Javascript",
  ".net core 6 and 8",
  "asp.net",
  ".net framework",
  "SQL Server",
  "JQuery",
  "IIS Server",
  "Bootstrap",
  "VBScript/ASP",
  "Typescript",
  "Angular",
  "Vue JS",
  "MariaDB",
  "Adobe XD",
  "Express JS",
  "AWS",
  "Azure",
  "Google Cloud",
  "Tailwind CSS",
];
---

<Layout 
  title="Jorge Osvaldo Perez Mendoza | Portfolio"
  description="Software Developer, Backend, Full Stack Web, Active Volunteer and Experience Hunter. Passionate about technology .NET, Azure, SQL Server."
  image="/icon.png"
>
  <Header />

  <main class="pt-20">
    <!-- HERO SECTION -->
    <section class="container flex flex-col justify-center min-h-[80vh] animate-fade-in">
      <p class="text-emerald-500 font-semibold font-heading mb-4">
        Hello, I'm
      </p>
      <h1>
        Jorge Osvaldo <br /><span class="text-gradient">Perez Mendoza</span>
      </h1>
      <h2 class="text-slate-400 text-2xl md:text-3xl mt-4 mb-8">
        Software Development Engineer
      </h2>
      <p class="max-w-[600px] text-lg text-slate-400 mb-12">
        Software Developer, Backend, Full Stack Web, Active Volunteer and
        Experience Hunter. Passionate about technology and board games,
        specializing in creating innovative web solutions that promote
        continuous improvement.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#experience" class="btn-primary no-underline text-center">View Experience</a>
        <a
          href="mailto:Jorge.Furiduri@gmail.com"
          class="btn-primary no-underline text-center !bg-transparent border !border-emerald-500 !text-emerald-500 hover:!bg-emerald-500/10 hover:!text-emerald-400"
          >Contact Me</a
        >
      </div>
    </section>

    <!-- EXPERIENCE SECTION -->
    <section id="experience" class="container glass-card mb-16">
      <h2 class="text-gradient">Work Experience</h2>
      <div class="mt-8 flex flex-col gap-8 pb-8">
        <div>
          <h3 class="font-heading mb-2">
            Resser Tecnologías <span class="text-base text-emerald-500 font-normal ml-2">(2024 - Present)</span>
          </h3>
          <p class="font-semibold mb-2 text-slate-50">
            Middle Developer
          </p>
          <p class="text-slate-400">
            Development Web APIs, .net core 8, SQL Server, Azure DevOps, Git,
            Azure Cloud. Scrum / Agile, Azure DevOps. Reporting solutions in
            Azure Functions. Testing process, detection and prevention of
            problems.
          </p>
        </div>
        <div class="w-full h-px bg-white/10"></div>
        <div>
          <h3 class="font-heading mb-2">
            Jabil Circuit de México <span class="text-base text-emerald-500 font-normal ml-2">(2019 - 2024)</span>
          </h3>
          <p class="font-semibold mb-2 text-slate-50">
            Programmer Analyst I
          </p>
          <p class="text-slate-400">
            Software development, web applications, APIs, database creation.
            Development in .net framework, SQL Server for databases. Technical
            documentation and end-user manual. Testing process, detection and
            prevention of problems.
          </p>
        </div>
        <div class="w-full h-px bg-white/10"></div>
        <div>
          <h3 class="font-heading mb-2">
            Talent Network (Jalisco Talent Land) <span class="text-base text-emerald-500 font-normal ml-2">(2017 - 2024)</span>
          </h3>
          <p class="font-semibold mb-2 text-slate-50">
            General Incident Leader
          </p>
          <p class="text-slate-400">
            Participation in editions. Conflict resolution, personalized
            customer service, use and management of personal data, crisis
            management, stress management.
          </p>
        </div>
      </div>
    </section>

    <!-- EDUCATION SECTION -->
    <section id="education" class="container glass-card mb-16">
      <h2 class="text-gradient">Education</h2>
      <div class="mt-8 flex flex-col gap-6 pb-8">
        <div>
          <h3 class="font-heading mb-2">Centro de Enseñanza Técnica Industrial</h3>
          <p class="text-slate-400">
            Ingeniería en Desarrollo de Software (University Studies - Graduate
            - Certificate)
          </p>
        </div>
        <div>
          <h3 class="font-heading mb-2">Preparatoria Número 10 UDG</h3>
          <p class="text-slate-400">
            Técnico Profesional En Informatica (High School/Secondary
            School/Preparatory School - Graduate)
          </p>
        </div>
      </div>
    </section>

    <!-- SKILLS & TECHNOLOGIES -->
    <section id="skills" class="container grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 pb-0">
      <!-- Domains & Skills -->
      <div class="glass-card">
        <h2 class="text-gradient">Skills</h2>
        <div class="flex flex-wrap gap-3 mt-6">
          {skills.map((s) => <TechPill name={s} />)}
        </div>
      </div>
      <!-- Technologies -->
      <div class="glass-card">
        <h2 class="text-gradient">Technologies</h2>
        <div class="flex flex-wrap gap-3 mt-6">
          {technologies.map((t) => <TechPill name={t} />)}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
