---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
---

<Layout title="Proyectos | Jorge Osvaldo Perez Mendoza">
  <Header />
  
  <main class="pt-[120px] container animate-fade-in">
    <h1 class="text-gradient">Mis Proyectos</h1>
    <p class="text-slate-400 text-lg mb-12 max-w-[600px]">
      Explora mis iniciativas fuera del trabajo. Desde proyectos sociales y comunitarios, hasta mi profunda pasión por el diseño de juegos de mesa.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <ProjectCard 
        title="Proyectos Sociales" 
        description="Iniciativas enfocadas a la construcción en comunidad, voluntariado, y generar impacto positivo en la sociedad."
        link="/es/projects/social-projects"
        tags={["Voluntariado", "Comunidad", "Liderazgo"]}
      />
      <ProjectCard 
        title="Juegos de Mesa" 
        description="Mi pasión por el diseño de juegos y mecánicas. Explorando nuevas formas de entretener y retar a los jugadores."
        link="/es/projects/board-games"
        tags={["Diseño", "Mecánicas", "Pasatiempos"]}
      />
    </div>
  </main>

  <Footer />
</Layout>
