---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<div class="inline-block bg-slate-800/70 border border-white/10 px-4 py-2 rounded-lg font-medium transition-all duration-300 hover:border-emerald-500 hover:bg-emerald-500/10 hover:text-emerald-400 hover:-translate-y-0.5">
  {name}
</div>
