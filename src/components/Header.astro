---
import logoImage from "../assets/Logo_Gcatcode.svg";
const currentLocale = Astro.currentLocale || "en";
const pathname = Astro.url.pathname;
// Resolve language switch path
let targetUrl = "/";
if (currentLocale === "en") {
  const purePath = pathname === "/" ? "" : pathname;
  targetUrl = "/es" + purePath;
} else {
  // if returning from es to en, remove the starting /es
  targetUrl = pathname.replace(/^\/es/, "") || "/";
}
const esActive = currentLocale === "es";
const enActive = currentLocale === "en";
---

<header
  class="fixed top-0 w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-white/10 py-4 transition-all"
>
  <div class="container flex justify-between items-center">
    <a
      href={currentLocale === "es" ? "/es/" : "/"}
      class="font-heading font-black text-2xl text-slate-50 flex items-center gap-2 hover:no-underline"
    >
      <img src={logoImage.src} alt="Logo" width="50" height="50" />
      Jorge <span class="text-gradient">Perez</span>
    </a>
    <div class="hidden md:flex items-center gap-4 md:gap-8">
      <ul class="hidden md:flex gap-8 list-none m-0 p-0">
        <li>
          <a
            class="text-slate-50 font-semibold hover:text-emerald-500 transition-colors"
            href={currentLocale === "es" ? "/es/" : "/"}
          >
            {currentLocale === "es" ? "Inicio" : "Home"}
          </a>
        </li>
        <li>
          <a
            class="text-slate-50 font-semibold hover:text-emerald-500 transition-colors"
            href={currentLocale === "es" ? "/es/projects" : "/projects"}
          >
            {currentLocale === "es" ? "Proyectos" : "Projects"}
          </a>
        </li>
        <li>
          <a
            href={targetUrl}
            aria-label="Cambiar Idioma"
            class="flex gap-1 items-center bg-slate-800/70 border border-white/10 text-slate-50 py-1.5 px-3 rounded-full cursor-pointer font-sans text-xs font-semibold transition-all duration-300 hover:border-emerald-500 hover:shadow-[0_0_10px_rgba(16,185,129,0.2)] group hover:no-underline"
          >
            <span
              class={`transition-colors duration-300 ${enActive ? "text-emerald-400" : "text-slate-400 group-hover:text-slate-50"}`}
              >EN</span
            >
            <span class="text-slate-400">/</span>
            <span
              class={`transition-colors duration-300 ${esActive ? "text-emerald-400" : "text-slate-400 group-hover:text-slate-50"}`}
              >ES</span
            >
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div id="mobile-menu" class="md:hidden w-full px-4">
    <ul class="list-none flex gap-8 items-center justify-center">
      <li>
        <a
          class="text-slate-50 font-semibold hover:text-emerald-500 transition-colors"
          href={currentLocale === "es" ? "/es/" : "/"}
        >
          {currentLocale === "es" ? "Inicio" : "Home"}
        </a>
      </li>
      <li>
        <a
          class="text-slate-50 font-semibold hover:text-emerald-500 transition-colors"
          href={currentLocale === "es" ? "/es/projects" : "/projects"}
        >
          {currentLocale === "es" ? "Proyectos" : "Projects"}
        </a>
      </li>
      <li>
        <a
          href={targetUrl}
          aria-label="Cambiar Idioma"
          class="flex gap-1 items-center bg-slate-800/70 border border-white/10 text-slate-50 py-1.5 px-3 rounded-full cursor-pointer font-sans text-xs font-semibold transition-all duration-300 hover:border-emerald-500 hover:shadow-[0_0_10px_rgba(16,185,129,0.2)] group hover:no-underline"
        >
          <span
            class={`transition-colors duration-300 ${enActive ? "text-emerald-400" : "text-slate-400 group-hover:text-slate-50"}`}
            >EN</span
          >
          <span class="text-slate-400">/</span>
          <span
            class={`transition-colors duration-300 ${esActive ? "text-emerald-400" : "text-slate-400 group-hover:text-slate-50"}`}
            >ES</span
          >
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {});
</script>
