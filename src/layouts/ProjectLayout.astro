---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { frontmatter } = Astro.props;
---

<Layout 
  title={frontmatter.pageTitle}
  description={frontmatter.description}
  image={frontmatter.image}
  type="article"
>
  <Header />

  <main class="pt-[120px] container animate-fade-in">
    <div>
      <a
        href={frontmatter.backLink}
        class="inline-flex items-center gap-2 mb-8 hover:no-underline"
      >
        &larr; {frontmatter.backText}
      </a>
    </div>

    <h1 class="text-gradient">{frontmatter.title}</h1>
    
    <div class="glass-card mt-12 min-h-[400px] flex flex-col items-center justify-center text-center prose prose-invert max-w-none prose-h2:text-3xl prose-h2:mb-4 prose-p:text-slate-400 prose-p:max-w-[500px] prose-p:mt-4 prose-p:leading-relaxed [&>svg]:w-16 [&>svg]:h-16 [&>svg]:text-emerald-500 [&>svg]:mb-6">
      <slot />
    </div>
  </main>

  <Footer />
</Layout>
